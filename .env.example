# MongoDB Connection (required)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxx.mongodb.net/phonedock?retryWrites=true&w=majority

# JWT Secret (required for auth — generate with: openssl rand -hex 32)
JWT_SECRET=your-random-64-char-secret

# Collector Secret (required for collector sync endpoint)
COLLECTOR_SECRET=your-secret-key-here

# Public Site URL (required for email links and SEO)
NEXT_PUBLIC_SITE_URL=https://phonedock-pi.vercel.app

# Email (optional — required for forgot-password to send reset links)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password

# Cloudinary (optional — required for image upload)
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_UPLOAD_PRESET=your-upload-preset
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret