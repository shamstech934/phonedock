# ===== REQUIRED (app won't start without these) =====
MONGODB_URI=                  # Full connection string from MongoDB Atlas > Connect > Drivers
JWT_SECRET=                   # Random string (32+ chars) for signing session cookies
NEXT_PUBLIC_BASE_URL=       # Public base URL for SEO (e.g. https://phonedock.pk)
CRON_SECRET=                  # Secret for authenticating cron job requests (Vercel Cron x-cron-secret header)

# ===== BOOTSTRAP ONLY (remove and redeploy immediately after setup) =====
FIRST_ADMIN_SETUP_KEY=       # One-time key for the first superadmin setup wizard

# ===== OPTIONAL — Features degrade gracefully if missing =====

# Collector (for Vercel serverless: max pages per job invocation, 0 = unlimited)
# COLLECTOR_PAGES_PER_INVOCATION=3

# Email (for forgot/reset password and contact form)
EMAIL_HOST=                   # SMTP host (e.g. smtp.gmail.com)
EMAIL_PORT=                   # SMTP port (e.g. 587)
EMAIL_USER=                   # SMTP username
EMAIL_PASS=                   # SMTP password
EMAIL_SECURE=false            # true for implicit TLS (commonly port 465)

# Cloudflare Turnstile (bot protection for reviews & contact form)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=   # Cloudflare Turnstile site key (public)
TURNSTILE_SECRET_KEY=              # Cloudflare Turnstile secret key (server-only)

# Cloudinary (for image uploads)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=  # Your Cloudinary cloud name
CLOUDINARY_API_KEY=           # Cloudinary API key
CLOUDINARY_API_SECRET=        # Cloudinary API secret
CLOUDINARY_UPLOAD_PRESET=     # Upload preset name (default: phonedock_images)

# ===== SCRIPT-ONLY (used by CLI scripts, not by the Next.js app) =====
# ADMIN_INITIAL_PASSWORD=     # Password for npm run admin:create (non-interactive mode)
# ADMIN_NAME=                 # Name for npm run admin:create (non-interactive mode)
# ADMIN_EMAIL=                # Email for npm run admin:create (non-interactive mode)
# ===== MONETIZATION & GROWTH =====
# Google AdSense publisher id, e.g. ca-pub-1234567890123456
NEXT_PUBLIC_ADSENSE_CLIENT=
# Create responsive ad units in AdSense and paste their numeric slot ids below
NEXT_PUBLIC_ADSENSE_HOME_TOP_SLOT=
NEXT_PUBLIC_ADSENSE_HOME_MIDDLE_SLOT=
NEXT_PUBLIC_ADSENSE_PHONE_SLOT=

# Google Analytics 4 measurement id, e.g. G-ABC123XYZ
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Microsoft Clarity project id
NEXT_PUBLIC_CLARITY_PROJECT_ID=
# Search engine ownership verification tokens
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Affiliate defaults (optional; use full tracked URLs supplied by each partner)
NEXT_PUBLIC_AFFILIATE_DARAZ_URL=
NEXT_PUBLIC_AFFILIATE_PRICEOYE_URL=
NEXT_PUBLIC_AFFILIATE_MEGA_URL=

# PhoneDock 2.0 launch note:
# After adding or changing any NEXT_PUBLIC_* value in Vercel, redeploy the project.
# AdSense ads.txt is generated automatically at /ads.txt from NEXT_PUBLIC_ADSENSE_CLIENT.

# Client account sessions (may reuse JWT_SECRET; 32+ random characters)
USER_JWT_SECRET=              # Independent 32+ character secret; leave blank only to intentionally reuse JWT_SECRET
REQUIRE_USER_EMAIL_VERIFICATION=false  # Enable only after SMTP and verification workflow are configured

# Server-only affiliate URLs are preferred. Legacy NEXT_PUBLIC_* values remain supported.
AFFILIATE_DARAZ_URL=
AFFILIATE_PRICEOYE_URL=
AFFILIATE_MEGA_URL=
AFFILIATE_ALLOWED_HOSTS=daraz.pk,priceoye.pk,mega.pk
# Optional observability release metadata (never put credentials here)
APP_ENV=development
APP_RELEASE=local

# ===== AI DATA ENRICHMENT (review-only drafts; never auto-published) =====
# OpenAI-compatible chat/completions endpoint or your approved AI gateway endpoint
AI_ENRICHMENT_API_URL=
AI_ENRICHMENT_API_KEY=
AI_ENRICHMENT_MODEL=
# Optional approved image-search API. Expected JSON: { images: [{ url, sourceUrl, title }] }
AI_IMAGE_SEARCH_URL=
AI_IMAGE_SEARCH_KEY=

# PhoneDock v9 PC6 AI Research Engine
# Required for evidence-grounded specs and Pakistan price research.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
TAVILY_API_KEY=
# Optional overrides
TAVILY_SEARCH_DEPTH=advanced
# OPENAI_CHAT_COMPLETIONS_URL=https://api.openai.com/v1/chat/completions
# TAVILY_SEARCH_URL=https://api.tavily.com/search
# Optional separate image-search provider
AI_IMAGE_SEARCH_URL=
AI_IMAGE_SEARCH_KEY=

# PhoneDock v9 PC8 bulk AI research safety limits
# Maximum phones that one persistent research job may contain (hard API cap is 10,000).
AI_RESEARCH_MAX_JOB_PHONES=500

# AI research provider (lightweight, admin-only)
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
# Alternative provider:
# AI_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=advanced
AI_RESEARCH_MAX_JOB_PHONES=10
