*.log
dev.log
dev.out.log
server.log

# OS files
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Lock files (keep package-lock.json, remove bun.lock)
bun.lock

# Tool output
tool-results/
agent-ctx/

# Uploads (user content, not source)
upload/

# Downloads (generated files, not source)
download/

# Examples (unrelated demos)
examples/

# Database files
db/
*.db

# Test & prompt dirs
test
prompt

# Skills directory
/skills/

# Old page parts
scripts/page_part*.tsx

# Python audit scripts
scripts/audit-report*.py

# Temporary files
*.tmp
*.bak

# Caddy (infra, not source)
Caddyfile

# Worklog
worklog.md