6:["$","div",null,{"className":"card-premium p-6 sm:p-8 animate-fade-in prose-sm","children":[["$","section",null,{"className":"mb-6","children":[["$","h2",null,{"className":"font-bold text-lg text-gray-900 mb-2","children":"1. Introduction"}],["$","p",null,{"className":"text-sm text-gray-600 leading-relaxed","children":"PhoneDock (\"we,\" \"our,\" or \"us\") respects your privacy and is committed to protecting your personal data. This Privacy Policy explains how we collect, use, disclose, and safeguard your information when you visit our website phonedock.pk (the \"Site\"). This policy applies to all visitors, users, and others who access the Site."}]]}],["$","section",null,{"className":"mb-6","children":[["$","h2",null,{"className":"font-bold text-lg text-gray-900 mb-2","children":"2. Information We Collect"}],["$","p",null,{"className":"text-sm text-gray-600 leading-relaxed mb-2","children":"We may collect the following types of information:"}],["$","ul",null,{"className":"text-sm text-gray-600 leading-relaxed space-y-1.5 list-disc pl-5","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Usage Data:"}]," We automatically collect information about how you interact with our Site, including pages visited, time spent on pages, search queries, phone models viewed, and comparison data. This helps us improve our services."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Device Information:"}]," We collect your IP address, browser type, browser version, operating system, device type, and screen resolution to optimize your experience."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Cookies:"}]," We use cookies and similar tracking technologies to enhance your browsing experience, remember your preferences (such as dark mode), and analyze site traffic."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Contact Information:"}]," If you contact us through our contact form, we collect your name, email address, and the content of your message."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Admin Data:"}]," For registered administrators, we store login credentials (encrypted), access logs, and management activity."]}]]}]]}],["$","section",null,{"className":"mb-6","children":[["$","h2",null,{"className":"font-bold text-lg text-gray-900 mb-2","children":"3. How We Use Your Information"}],["$","p",null,{"className":"text-sm text-gray-600 leading-relaxed","children":"We use the collected information for the following purposes:"}],["$","ul",null,{"className":"text-sm text-gray-600 leading-relaxed space-y-1.5 list-disc pl-5 mt-2","children":[["$","li",null,{"children":"To provide, maintain, and improve our phone database and comparison tools"}],["$","li",null,{"children":"To personalize your experience, including remembering your preferences"}],["$","li",null,{"children":"To analyze usage trends and optimize site performance"}],["$","li",null,{"children":"To respond to your inquiries and requests"}],["$","li",null,{"children":"To detect and prevent fraud or abuse of our platform"}],["$","li",null,{"children":"To comply with legal obligations"}]]}]]}],["$","section",null,{"className":"mb-6","children":[["$","h2",null,{"className":"font-bold text-lg text-gray-900 mb-2","children":"4. Cookies"}],["$","p",null,{"className":"text-sm text-gray-600 leading-relaxed","children":"PhoneDock uses cookies — small text files placed on your device — to enhance your experience. We use both session cookies (which expire when you close your browser) and persistent cookies (which remain until they expire or are deleted). You can control cookies through your browser settings; however, disabling cookies may affect certain features of the Site."}],["$","p",null,{"className":"text-sm text-gray-600 leading-relaxed mt-2","children":"We also use third-party analytics services (such as Google Analytics) that may set their own cookies to help us understand how visitors use our Site."}]]}],"$