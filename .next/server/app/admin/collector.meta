{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/admin/layout,_N_T_/admin/collector/layout,_N_T_/admin/collector/page,_N_T_/admin/collector"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/admin/collector/__PAGE__",
    "/admin/collector",
    "/admin",
    "/_index",
    "/_head"
  ]
}